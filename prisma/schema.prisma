generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum Plan {
  starter
  growth
  enterprise
}

enum Currency {
  INR
}

enum ConnectionStatus {
  pending
  connected
  disconnected
}

enum WalletReferenceType {
  manual_topup
  campaign_send
  adjustment
}

enum MessageTemplateCategory {
  marketing
  utility
}

enum TemplateStatus {
  approved
  pending
  rejected
}

enum CampaignStatus {
  draft
  scheduled
  sending
  delivered
}

enum RecipientStatus {
  queued
  sent
  delivered
  failed
}

model Workspace {
  id                  String               @id @default(cuid())
  name                String
  plan                Plan                 @default(starter)
  currency            Currency             @default(INR)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  users               User[]
  whatsAppConnections WhatsAppConnection[]
  contacts            Contact[]
  contactTags         ContactTag[]
  templates           MessageTemplate[]
  campaigns           Campaign[]
  recipients          CampaignRecipient[]
  walletTransactions  WalletTransaction[]
}

model User {
  id                 String       @id @default(cuid())
  workspaceId        String
  name               String
  email              String       @unique
  onboardingComplete Boolean      @default(false)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  workspace          Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sessions           AppSession[]
}

model AppSession {
  id            String   @id @default("primary")
  currentUserId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  currentUser   User?    @relation(fields: [currentUserId], references: [id], onDelete: SetNull)
}

model WhatsAppConnection {
  id                     String           @id @default(cuid())
  workspaceId            String
  metaBusinessPortfolioId String?
  wabaId                 String?
  phoneNumberId          String?
  phoneNumber            String
  businessName           String
  businessPortfolio      String
  status                 ConnectionStatus @default(pending)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  workspace              Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Contact {
  id         String       @id @default(cuid())
  workspaceId String
  name       String
  phone      String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  workspace  Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tags       ContactTag[]
  recipients CampaignRecipient[]

  @@unique([workspaceId, phone])
}

model ContactTag {
  id         String    @id @default(cuid())
  workspaceId String
  contactId  String
  tag        String
  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact    Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([contactId, tag])
}

model MessageTemplate {
  id         String                  @id @default(cuid())
  workspaceId String
  name       String
  category   MessageTemplateCategory
  status     TemplateStatus
  language   String
  body       String
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt
  workspace  Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaigns  Campaign[]
}

model Campaign {
  id            String           @id @default(cuid())
  workspaceId    String
  templateId     String
  name          String
  status        CampaignStatus
  estimatedCost Float
  spent         Float            @default(0)
  scheduledFor  DateTime?
  launchedAt    DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  workspace     Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  template      MessageTemplate  @relation(fields: [templateId], references: [id], onDelete: Restrict)
  recipients    CampaignRecipient[]
}

model CampaignRecipient {
  id          String          @id @default(cuid())
  workspaceId  String
  campaignId   String
  contactId    String
  status      RecipientStatus @default(queued)
  cost        Float
  createdAt   DateTime        @default(now())
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaign    Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact     Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model WalletTransaction {
  id           String              @id @default(cuid())
  workspaceId   String
  type         String
  amount       Float
  description  String
  referenceType WalletReferenceType
  referenceId  String?
  balanceAfter Float
  createdAt    DateTime            @default(now())
  workspace    Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}
